        "type": "datasource",
        "label": "Loki datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Timer 2.0 — Audit Events",
  "uid": "timer-audit",
