# Copy this file to .env and fill in values before running the server.
# .env is gitignored and must never be committed.

# Required. Generate a value with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to True only for local development. Never True in production.
DEBUG=False

# Comma-separated list of hostnames/IPs Django will serve.
# Examples: localhost,127.0.0.1  or  asctimer.olyortho.local
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgres://timer:password@localhost:5432/timer

# Log verbosity for the django and timer.api/timer.auth loggers.
# timer.audit is always INFO regardless of this value.
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
